# ─────────────────────────────────────────────
#  Nifty 50 Signal Bot — Environment Variables
# ─────────────────────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# NewsAPI (free at newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# Settings
SIGNAL_THRESHOLD=0.65        # Min probability to fire a signal (0.0–1.0)
SWING_TARGET_DAYS=5          # Lookahead days for label creation
SWING_TARGET_PCT=2.0         # % gain threshold to label as BUY
MIN_SIGNAL_CONFIDENCE=0.65   # Minimum model confidence to send alert
MAX_SIGNALS_PER_RUN=5        # Max stocks to alert per daily run
MARKET_CLOSE_HOUR=16         # Hour (IST) to run the daily job
